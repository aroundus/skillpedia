{
  "version": "0.2.0",
  "compounds": [
    {
      "configurations": ["server", "chrome"],
      "name": "dev",
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "console": "integratedTerminal",
      "name": "server",
      "request": "launch",
      "runtimeArgs": ["run", "dev"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "type": "node",
    },
    {
      "name": "chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:3000",
      "userDataDir": "${userHome}/.vscode/chrome-profile",
      "webRoot": "${workspaceFolder}/.vscode/chrome",
    }
  ]
}
